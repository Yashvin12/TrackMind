# Production Environment Variables

# App
APP_NAME="TrackMind Production"
DEBUG=false

# Database
# For docker-compose, use the postgres container:
DATABASE_URL="postgresql+asyncpg://trackmind:securepassword@db:5432/trackmind_db"
# For local SQLite testing without docker:
# DATABASE_URL="sqlite+aiosqlite:///./trackmind.db"

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis (Optional but recommended for production)
REDIS_URL="redis://redis:6379/0"

# Security
# Define permitted origins as a JSON-formatted list
CORS_ORIGINS=["https://trackmind.yourdomain.com", "http://localhost:5173"]

# Optimization & ML
SIMULATION_SPEED=1.0
SOLVER_TYPE="cp_sat"
