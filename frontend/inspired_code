<div class="h-[28px] border-b border-slate-300 flex items-center px-sm bg-slate-100 font-label-caps text-label-caps text-slate-500 uppercase tracking-[0.07em]">
<div class="w-[15%]">TRAIN ID</div>
<div class="w-[15%]">TYPE</div>
<div class="w-[20%]">SECTION</div>
<div class="w-[15%]">SPEED</div>
<div class="w-[15%]">DELAY</div>
<div class="w-[20%]">AI CONFIDENCE</div>
</div>
<div class="flex-1 overflow-y-auto">
<!-- Row 1 -->
<div class="flex items-center px-sm h-row-height-dense border-b border-slate-200 bg-white font-data-mono text-data-mono text-slate-900">
<div class="w-[15%]">T-12005</div>
<div class="w-[15%] text-slate-500">PAX-EXP</div>
<div class="w-[20%]">SEC_A-01</div>
<div class="w-[15%]">120 km/h</div>
<div class="w-[15%] text-slate-500">+0m</div>
<div class="w-[20%] text-slate-500">99.2%</div>
</div>
<!-- Row 2 -->
<div class="flex items-center px-sm h-row-height-dense border-b border-slate-200 bg-slate-50 font-data-mono text-data-mono text-slate-900">
<div class="w-[15%]">T-08441</div>
<div class="w-[15%] text-slate-500">FRT-HVY</div>
<div class="w-[20%]">SEC_B-04</div>
<div class="w-[15%]">85 km/h</div>
<div class="w-[15%] text-amber-600 bg-amber-50 px-xs py-[2px] rounded-base inline-block w-max">-2m</div>
<div class="w-[20%] text-slate-500">94.5%</div>
</div>
<!-- Row 3 (Critical) -->
<div class="flex items-center px-sm h-row-height-dense border-b border-slate-200 bg-red-50 font-data-mono text-data-mono text-slate-900">
<div class="w-[15%] font-data-mono-bold text-data-mono-bold">T-12127</div>
<div class="w-[15%] text-slate-500">PAX-LOC</div>
<div class="w-[20%] font-data-mono-bold text-data-mono-bold">SEC_C-09</div>
<div class="w-[15%]">0 km/h</div>
<div class="w-[15%] text-red-600 bg-white px-xs py-[2px] border border-red-200 rounded-base inline-block w-max">-12m</div>
<div class="w-[20%] text-slate-500">88.1%</div>
</div>
<!-- Row 4 -->
<div class="flex items-center px-sm h-row-height-dense border-b border-slate-200 bg-white font-data-mono text-data-mono text-slate-900">
<div class="w-[15%]">T-0992X</div>
<div class="w-[15%] text-slate-500">FRT-PRI</div>
<div class="w-[20%]">SEC_C-10</div>
<div class="w-[15%]">60 km/h</div>
<div class="w-[15%] text-slate-500">+1m</div>
<div class="w-[20%] text-slate-500">97.8%</div>
</div>
</div>
</div>
</main>
</div>
<!-- Zone 4: Scenario Lab (Floating Modal) -->
<div class="fixed bottom-[60px] right-[16px] w-[320px] bg-white border border-slate-300 rounded-base shadow-none z-50 flex flex-col">
<div class="h-[28px] border-b border-slate-200 flex items-center justify-between px-sm bg-slate-50">
<span class="font-panel-header text-panel-header">SCENARIO LAB</span>
<button class="text-slate-500 hover:text-slate-900"><span class="material-symbols-outlined text-[16px]">close</span></button>
</div>
<div class="p-md flex flex-col gap-md">
<div>
<label class="block font-label-caps text-label-caps text-slate-500 mb-xs uppercase tracking-[0.07em]">TEST PARAMETER</label>
<input class="w-full h-[28px] border border-slate-300 rounded-base px-sm font-data-mono-sm text-data-mono-sm text-slate-900 focus:border-blue-600 focus:ring-0 outline-none" type="text" value="Signal Red at BLK_1"/>
</div>
<div class="border border-slate-200 rounded-base overflow-hidden">
<div class="flex border-b border-slate-200 bg-slate-50 font-label-caps text-label-caps text-slate-500 text-center">
<div class="w-1/2 p-xs border-r border-slate-200">CURRENT</div>
<div class="w-1/2 p-xs">SIMULATED</div>
</div>
<div class="flex text-center font-data-mono text-data-mono bg-white">
<div class="w-1/2 p-sm border-r border-slate-200">
<div class="text-slate-500 text-[10px]">THROUGHPUT</div>
<div>98%</div>
</div>
<div class="w-1/2 p-sm">
<div class="text-slate-500 text-[10px]">THROUGHPUT</div>
<div class="text-amber-600">92%</div>
</div>
</div>
</div>
<button class="w-full h-[30px] bg-slate-900 text-white font-label-caps text-label-caps rounded-base hover:bg-slate-800 transition-colors">RUN SIMULATION</button>
</div>
</div>
<!-- Footer -->
<footer class="bg-surface-dim dark:bg-surface-dim fixed bottom-0 w-full h-row-height-dense border-t border-outline-variant flex justify-between items-center px-lg w-full z-50">
<span class="font-data-mono-sm text-data-mono-sm text-on-surface-variant">TrackMind v2.4.1 | System Health: Nominal</span>
<div class="flex gap-lg">
<span class="font-data-mono-sm text-data-mono-sm text-on-surface-variant">Session: 04:22:15</span>
<a class="font-data-mono-sm text-data-mono-sm text-on-surface-variant hover:text-primary transition-colors" href="#">Log Out</a>
</div>
</footer>
</body></html>