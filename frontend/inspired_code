<body class="bg-slate-100 text-slate-900 font-body-base text-body-base h-screen overflow-hidden flex flex-col antialiased">
<!-- TopNavBar -->
<header class="bg-surface-container-highest dark:bg-surface-container-highest fixed top-0 w-full h-[44px] border-b border-outline-variant flex justify-between items-center px-lg w-full z-50">
<div class="flex items-center gap-xl">
<span class="font-display-lg text-display-lg font-bold text-primary dark:text-primary-fixed">TrackMind</span>
<nav class="hidden md:flex gap-lg">
<a class="text-on-surface-variant font-medium hover:bg-surface-container-low transition-colors px-sm py-xs rounded-base" href="#">Throughput: 98%</a>
<a class="text-on-surface-variant font-medium hover:bg-surface-container-low transition-colors px-sm py-xs rounded-base" href="#">Avg Delay: 1.2m</a>
<a class="text-on-surface-variant font-medium hover:bg-surface-container-low transition-colors px-sm py-xs rounded-base" href="#">Conflicts: 0</a>
</nav>
</div>
<div class="flex items-center gap-sm">
<button class="p-xs hover:bg-surface-container-low transition-colors rounded-base text-on-surface-variant"><span class="material-symbols-outlined">timer</span></button>
<button class="p-xs hover:bg-surface-container-low transition-colors rounded-base text-on-surface-variant"><span class="material-symbols-outlined">wifi</span></button>
<button class="p-xs hover:bg-surface-container-low transition-colors rounded-base text-on-surface-variant"><span class="material-symbols-outlined">settings</span></button>
</div>
</header>
<!-- Main Workspace -->
<div class="flex flex-1 mt-[44px] mb-row-height-dense overflow-hidden">
<!-- SideNavBar -->
<nav class="bg-surface-container-low dark:bg-surface-container-low fixed left-0 top-[44px] w-[56px] h-[calc(100vh-44px)] border-r border-outline-variant flex flex-col items-center py-md space-y-md z-40">
<div class="mb-lg flex flex-col items-center gap-xs">
<div class="w-[32px] h-[32px] rounded-base bg-slate-300 overflow-hidden" data-alt="A clinical, highly detailed headshot of a mature female railway operator wearing a crisp white collared shirt and subtle headset. She is set against a clean, technical light-grey background. The lighting is bright and even, highlighting professionalism and focus, fitting a high-performance minimalist interface.">
<!-- Placeholder for Avatar -->
</div>
</div>
<a class="border-l-4 border-primary bg-secondary-fixed text-on-secondary-fixed p-sm w-full flex justify-center hover:bg-surface-container-high cursor-pointer transition-all duration-150" href="#" title="Map">
<span class="material-symbols-outlined filled">map</span>
</a>
<a class="text-on-surface-variant p-sm w-full flex justify-center hover:bg-surface-container-high cursor-pointer transition-all duration-150 border-l-4 border-transparent" href="#" title="Register">
<span class="material-symbols-outlined">list_alt</span>
</a>
<a class="text-on-surface-variant p-sm w-full flex justify-center hover:bg-surface-container-high cursor-pointer transition-all duration-150 border-l-4 border-transparent" href="#" title="Lab">
<span class="material-symbols-outlined">science</span>
</a>
</nav>
<!-- Canvas Area -->
<main class="ml-[56px] flex-1 flex flex-col p-baseline gap-baseline overflow-hidden">
<!-- Top Zones (Map & Queue) -->
<div class="flex flex-1 gap-baseline overflow-hidden">
<!-- Zone 1: Network Map -->
<div class="w-[60%] bg-surface-container-lowest border border-slate-300 rounded-base relative overflow-hidden flex flex-col">
<div class="h-[28px] border-b border-slate-200 flex items-center px-sm bg-slate-50">
<span class="font-panel-header text-panel-header">ZONE ALPHA TOPOLOGY</span>
</div>
<div class="flex-1 grid-bg relative p-lg">
<!-- Y-Axis Labels -->
<div class="absolute left-md top-lg bottom-lg w-[40px] flex flex-col justify-between font-data-mono-sm text-data-mono-sm text-slate-500">
<span>STN-A</span>
<span>STN-B</span>
<span>STN-C</span>
<span>STN-D</span>
</div>
<!-- Tracks & Trains -->
<div class="ml-[50px] h-full relative">
<!-- Track Line 1 -->
<div class="absolute top-[10%] left-0 w-full h-[3px] bg-slate-300"></div>
<div class="absolute top-[10%] left-[20%] -translate-y-1/2 bg-blue-600 text-white font-data-mono-sm text-data-mono-sm px-xs py-[2px] rounded-base">T-12005</div>
<!-- Track Line 2 -->
<div class="absolute top-[40%] left-0 w-full h-[3px] bg-slate-300"></div>
<div class="absolute top-[40%] left-[50%] -translate-y-1/2 bg-green-500 text-white font-data-mono-sm text-data-mono-sm px-xs py-[2px] rounded-base">T-08441</div>
<!-- Track Line 3 (Conflict) -->
<div class="absolute top-[70%] left-0 w-[60%] h-[3px] bg-slate-300"></div>
<div class="absolute top-[70%] left-[60%] w-[20%] h-[3px] bg-red-600 animate-pulse-red"></div>
<div class="absolute top-[70%] left-[80%] w-[20%] h-[3px] bg-slate-300"></div>
<div class="absolute top-[70%] left-[55%] -translate-y-1/2 bg-amber-500 text-white font-data-mono-sm text-data-mono-sm px-xs py-[2px] rounded-base">T-12127</div>
<div class="absolute top-[70%] left-[75%] -translate-y-1/2 bg-red-600 text-white font-data-mono-sm text-data-mono-sm px-xs py-[2px] rounded-base">T-0992X</div>
</div>
</div>
</div>
<!-- Zone 2: Action Queue -->
<div class="w-[40%] bg-surface-container-lowest border border-slate-300 rounded-base flex flex-col overflow-hidden">
<div class="h-[28px] border-b border-slate-200 flex items-center justify-between px-sm bg-slate-50">
<span class="font-panel-header text-panel-header">AI INTERVENTIONS</span>
<span class="font-data-mono-sm text-data-mono-sm bg-slate-200 px-xs rounded-base text-slate-700">3 PENDING</span>
</div>
<div class="flex-1 overflow-y-auto p-sm flex flex-col gap-sm bg-slate-100">
<!-- Action Card: Critical -->
<div class="bg-white border border-slate-300 rounded-base relative pl-[15px] p-md">
<div class="absolute left-0 top-0 bottom-0 w-[3px] bg-red-600"></div>
<div class="flex justify-between items-start mb-sm">
<span class="font-label-caps text-label-caps text-red-600 uppercase">CRITICAL CONFLICT</span>
<span class="font-data-mono-sm text-data-mono-sm bg-red-50 text-red-600 border border-red-200 px-xs py-[2px] rounded-base">-12 min delay</span>
</div>
<p class="font-panel-header text-panel-header text-slate-900 mb-xs">Hold Train 12127 at Station LNL</p>
<p class="font-body-base text-body-base text-slate-500 mb-md leading-snug">Projected routing collision on Block 4. Holding T-12127 allows priority freight T-0992X to clear the single-line segment.</p>
<div class="flex gap-sm">
<button class="h-[30px] px-md bg-blue-600 text-white font-label-caps text-label-caps rounded-base hover:bg-blue-700 transition-colors">EXECUTE</button>
<button class="h-[30px] px-md bg-white border border-slate-300 text-slate-900 font-label-caps text-label-caps rounded-base hover:bg-slate-50 transition-colors">OVERRIDE</button>
</div>
</div>
<!-- Action Card: Warning -->
<div class="bg-white border border-slate-300 rounded-base relative pl-[15px] p-md">
<div class="absolute left-0 top-0 bottom-0 w-[3px] bg-amber-500"></div>
<div class="flex justify-between items-start mb-sm">
<span class="font-label-caps text-label-caps text-amber-600 uppercase">SPEED ADVISORY</span>
<span class="font-data-mono-sm text-data-mono-sm bg-amber-50 text-amber-600 border border-amber-200 px-xs py-[2px] rounded-base">+4 min slack</span>
</div>
<p class="font-panel-header text-panel-header text-slate-900 mb-xs">Reduce T-08441 to 60km/h</p>
<p class="font-body-base text-body-base text-slate-500 mb-md leading-snug">Approaching maintenance zone MZ-2. Gradual deceleration minimizes energy consumption while meeting scheduled arrival.</p>
<div class="flex gap-sm">
<button class="h-[30px] px-md bg-blue-600 text-white font-label-caps text-label-caps rounded-base hover:bg-blue-700 transition-colors">EXECUTE</button>
<button class="h-[30px] px-md bg-white border border-slate-300 text-slate-900 font-label-caps text-label-caps rounded-base hover:bg-slate-50 transition-colors">DISMISS</button>
</div>
</div>
</div>
</div>
</div>
<!-- Zone 3: Train Register -->
